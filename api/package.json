{
  "name": "qlens-api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:migrate": "wrangler d1 execute qlens-db --remote --file=migrations/0001_init.sql",
    "db:migrate:local": "wrangler d1 execute qlens-db --local --file=migrations/0001_init.sql",
    "db:console": "wrangler d1 execute qlens-db --remote --command",
    "secret:jwt": "wrangler secret put JWT_SECRET",
    "secret:google": "wrangler secret put GOOGLE_CLIENT_SECRET",
    "secret:resend": "wrangler secret put RESEND_API_KEY"
  },
  "devDependencies": {
    "wrangler": "^3.78.0"
  }
}
